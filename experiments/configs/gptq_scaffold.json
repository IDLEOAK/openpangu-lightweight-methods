{
  "experiment_name": "gptq_scaffold",
  "method": "gptq",
  "model_path": ".",
  "hf_home": ".hf_cache",
  "device_map": "auto",
  "torch_dtype": "auto",
  "system_prompt": "You are a helpful assistant.",
  "calibration_data": {
    "path": "experiments/data/demo_prompts.jsonl",
    "limit": 4
  },
  "evaluation": {
    "run_generation": true,
    "run_perplexity": true,
    "generation_samples": 2,
    "max_new_tokens": 8,
    "perplexity_max_length": 256
  },
  "module_selection": {
    "include_groups": [
      "attention",
      "mlp"
    ],
    "exclude_patterns": [
      "lm_head"
    ]
  },
  "gptq": {
    "mode": "scaffold",
    "bits": 4,
    "group_size": 128,
    "desc_act": false,
    "damp_percent": 0.01
  },
  "output_dir": "experiments/results"
}
