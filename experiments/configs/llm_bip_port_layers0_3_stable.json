{
  "experiment_name": "llm_bip_port_layers0_3_stable",
  "method": "llm_bip",
  "model_path": ".",
  "hf_home": ".hf_cache",
  "device_map": "",
  "torch_dtype": "auto",
  "system_prompt": "You are a helpful assistant.",
  "calibration_data": {
    "path": "experiments/data/demo_prompts.jsonl",
    "limit": 4,
    "max_length": 128
  },
  "evaluation_data": {
    "path": "experiments/data/formal_eval_prompts.jsonl",
    "limit": 8,
    "max_length": 192
  },
  "evaluation": {
    "run_generation": false,
    "run_perplexity": true,
    "run_post_prune_perplexity": true,
    "generation_samples": 0,
    "max_new_tokens": 8,
    "perplexity_max_length": 192
  },
  "module_selection": {
    "include_groups": [
      "attention",
      "mlp"
    ],
    "exclude_patterns": [
      "lm_head"
    ]
  },
  "llm_bip": {
    "mode": "structured_prune",
    "sparsity": 0.08,
    "group_size": 256,
    "scoring_samples": 2,
    "true_sequential": true,
    "min_layer": 0,
    "max_layer": 4,
    "prune_only": "",
    "invert": false
  },
  "output_dir": "experiments/results"
}
