{
  "experiment_name": "sparsegpt_port_minimal",
  "method": "sparsegpt",
  "model_path": ".",
  "hf_home": ".hf_cache",
  "device_map": "",
  "torch_dtype": "auto",
  "system_prompt": "You are a helpful assistant.",
  "calibration_data": {
    "path": "experiments/data/demo_prompts.jsonl",
    "limit": 2,
    "max_length": 128
  },
  "evaluation": {
    "run_generation": false,
    "run_perplexity": true,
    "run_post_prune_perplexity": true,
    "generation_samples": 0,
    "max_new_tokens": 8,
    "perplexity_max_length": 128
  },
  "module_selection": {
    "include_groups": [
      "attention",
      "mlp"
    ],
    "exclude_patterns": [
      "lm_head"
    ]
  },
  "sparsegpt": {
    "mode": "sequential_prune",
    "sparsity": 0.3,
    "pattern": "unstructured",
    "block_size": 128,
    "damp_percent": 0.01,
    "prunen": 0,
    "prunem": 0,
    "true_sequential": true,
    "min_layer": 0,
    "max_layer": 1,
    "prune_only": "",
    "invert": false,
    "save_dir": ""
  },
  "output_dir": "experiments/results"
}
