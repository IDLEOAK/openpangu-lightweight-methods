{
  "experiment_name": "gptq_port_full34_generation",
  "method": "gptq",
  "model_path": ".",
  "hf_home": ".hf_cache",
  "device_map": "",
  "torch_dtype": "auto",
  "system_prompt": "You are a helpful assistant.",
  "calibration_data": {
    "path": "experiments/data/demo_prompts.jsonl",
    "limit": 4,
    "max_length": 128
  },
  "evaluation_data": {
    "path": "experiments/data/formal_eval_prompts.jsonl",
    "limit": 16,
    "max_length": 192
  },
  "evaluation": {
    "run_generation": true,
    "run_perplexity": true,
    "run_post_quant_perplexity": true,
    "generation_samples": 2,
    "max_new_tokens": 8,
    "perplexity_max_length": 192
  },
  "module_selection": {
    "include_groups": [
      "attention",
      "mlp"
    ],
    "exclude_patterns": [
      "lm_head"
    ]
  },
  "gptq": {
    "mode": "sequential_quant",
    "bits": 4,
    "group_size": 128,
    "desc_act": false,
    "damp_percent": 0.01,
    "block_size": 128,
    "true_sequential": true,
    "static_groups": false,
    "sym": false,
    "min_layer": 0,
    "max_layer": 34,
    "quantize_only": "",
    "invert": false,
    "save_dir": ""
  },
  "output_dir": "experiments/results"
}
